# buildd.env — environment for the buildd systemd unit (copy to /etc/bko/buildd.env, chmod 0600).
# Secrets go HERE, never on the command line (they'd show in `ps` / the unit file).

# Break-glass admin token for the routing API (X-Buildkit-Operator-Admin-Token): lets the local CLI /
# smoke test route without OIDC. Generate one: `openssl rand -hex 32`.
BUILDKIT_OPERATOR_ADMIN_TOKEN=change-me

# Optional legacy bearer accepted on Authorization (used only when OIDC is off).
# BUILDKIT_OPERATOR_AUTH_TOKEN=

# Optional OIDC for CI callers (forge-signed tokens). Point buildd at a config file with --oidc-config
# and/or set BUILDKIT_OPERATOR_OIDC_* here — same surface as the Kubernetes backend.
